<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INFO GLOBAL - For The Best And Reliable Global Informations</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-green: #1a5f2a;
            --dark-green: #0d3d16;
            --light-green: #2d8a3e;
            --accent-green: #4ade80;
            --white: #ffffff;
            --off-white: #f8fafc;
            --gray: #64748b;
            --dark-gray: #1e293b;
            --border: #e2e8f0;
        }

        body {
            font-family: 'Roboto', sans-serif;
            background-color: var(--off-white);
            color: var(--dark-gray);
            line-height: 1.6;
        }

        /* Top Bar */
        .top-bar {
            background-color: var(--dark-green);
            color: var(--white);
            padding: 8px 0;
            font-size: 13px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .top-bar-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .date-weather {
            display: flex;
            gap: 20px;
        }

        .social-links {
            display: flex;
            gap: 15px;
        }

        .social-links a {
            color: var(--white);
            text-decoration: none;
            transition: color 0.3s;
        }

        .social-links a:hover {
            color: var(--accent-green);
        }

        /* Header & Logo */
        .main-header {
            background-color: var(--white);
            padding: 20px 0;
            border-bottom: 3px solid var(--primary-green);
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo-section {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo-icon {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--primary-green) 0%, var(--light-green) 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-weight: 900;
            font-size: 24px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .logo-text h1 {
            font-family: 'Playfair Display', serif;
            font-size: 36px;
            font-weight: 900;
            color: var(--primary-green);
            letter-spacing: -1px;
            line-height: 1;
        }

        .logo-text .domain {
            font-size: 14px;
            color: var(--light-green);
            font-weight: 500;
            letter-spacing: 2px;
        }

        .slogan {
            font-size: 12px;
            color: var(--gray);
            font-style: italic;
            margin-top: 4px;
        }

        .header-ad {
            width: 468px;
            height: 60px;
            background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
            border: 2px dashed var(--light-green);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-green);
            font-weight: 500;
            border-radius: 4px;
        }

        /* Navigation */
        .main-nav {
            background-color: var(--primary-green);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .nav-content {
            display: flex;
            align-items: center;
        }

        .nav-menu {
            display: flex;
            list-style: none;
            flex: 1;
        }

        .nav-item {
            position: relative;
        }

        .nav-item > a {
            display: block;
            color: var(--white);
            text-decoration: none;
            padding: 16px 20px;
            font-weight: 500;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.3s;
        }

        .nav-item:hover > a {
            background-color: var(--dark-green);
            color: var(--accent-green);
        }

        /* Dropdown Menus */
        .dropdown {
            position: absolute;
            top: 100%;
            left: 0;
            background-color: var(--white);
            min-width: 200px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.3s;
            border-top: 3px solid var(--accent-green);
        }

        .nav-item:hover .dropdown {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .dropdown li {
            list-style: none;
            border-bottom: 1px solid var(--border);
        }

        .dropdown li:last-child {
            border-bottom: none;
        }

        .dropdown a {
            display: block;
            padding: 12px 20px;
            color: var(--dark-gray);
            text-decoration: none;
            font-size: 14px;
            transition: all 0.3s;
        }

        .dropdown a:hover {
            background-color: #f0fdf4;
            color: var(--primary-green);
            padding-left: 25px;
        }

        .search-box {
            display: flex;
            align-items: center;
            background-color: var(--dark-green);
            padding: 8px 15px;
            border-radius: 4px;
        }

        .search-box input {
            background: none;
            border: none;
            color: var(--white);
            outline: none;
            width: 150px;
            font-size: 14px;
        }

        .search-box input::placeholder {
            color: rgba(255,255,255,0.6);
        }

        .search-btn {
            background: none;
            border: none;
            color: var(--white);
            cursor: pointer;
            font-size: 16px;
        }

        /* Breaking News Ticker */
        .breaking-news {
            background-color: var(--dark-gray);
            color: var(--white);
            padding: 12px 0;
            overflow: hidden;
        }

        .ticker-wrapper {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .ticker-label {
            background-color: var(--accent-green);
            color: var(--dark-green);
            padding: 4px 12px;
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            white-space: nowrap;
            border-radius: 2px;
        }

        .ticker-content {
            flex: 1;
            overflow: hidden;
        }

        .ticker-text {
            display: inline-block;
            white-space: nowrap;
            animation: ticker 30s linear infinite;
        }

        @keyframes ticker {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }

        /* Main Content Layout */
        .main-content {
            padding: 30px 0;
        }

        .content-grid {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 30px;
        }

        /* Hero Section */
        .hero-section {
            margin-bottom: 40px;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
        }

        .hero-main {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        .hero-image {
            width: 100%;
            height: 400px;
            object-fit: cover;
            background: linear-gradient(135deg, #166534 0%, #15803d 100%);
        }

        .hero-content {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
            padding: 30px;
            color: var(--white);
        }

        .category-tag {
            display: inline-block;
            background-color: var(--accent-green);
            color: var(--dark-green);
            padding: 4px 12px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 10px;
            border-radius: 2px;
        }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 10px;
        }

        .hero-excerpt {
            font-size: 14px;
            opacity: 0.9;
            line-height: 1.5;
        }

        .hero-side {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .side-card {
            background-color: var(--white);
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s;
        }

        .side-card:hover {
            transform: translateY(-2px);
        }

        .side-image {
            width: 100%;
            height: 120px;
            object-fit: cover;
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        }

        .side-content {
            padding: 15px;
        }

        .side-category {
            color: var(--light-green);
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .side-title {
            font-size: 14px;
            font-weight: 600;
            line-height: 1.4;
            color: var(--dark-gray);
        }

        /* Section Headers */
        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 3px solid var(--primary-green);
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 700;
            color: var(--primary-green);
            position: relative;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -13px;
            left: 0;
            width: 60px;
            height: 3px;
            background-color: var(--accent-green);
        }

        .view-all {
            color: var(--light-green);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: color 0.3s;
        }

        .view-all:hover {
            color: var(--primary-green);
        }

        /* News Grid */
        .news-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }

        .news-card {
            background-color: var(--white);
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            transition: all 0.3s;
        }

        .news-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .news-image {
            width: 100%;
            height: 180px;
            object-fit: cover;
            background: linear-gradient(135deg, #86efac 0%, #4ade80 100%);
            position: relative;
        }

        .news-image::after {
            content: attr(data-category);
            position: absolute;
            top: 10px;
            left: 10px;
            background-color: var(--primary-green);
            color: var(--white);
            padding: 4px 10px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            border-radius: 2px;
        }

        .news-body {
            padding: 20px;
        }

        .news-meta {
            display: flex;
            gap: 15px;
            font-size: 12px;
            color: var(--gray);
            margin-bottom: 10px;
        }

        .news-title {
            font-size: 16px;
            font-weight: 700;
            line-height: 1.4;
            margin-bottom: 10px;
            color: var(--dark-gray);
        }

        .news-excerpt {
            font-size: 14px;
            color: var(--gray);
            line-height: 1.5;
        }

        /* Sidebar */
        .sidebar {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .sidebar-widget {
            background-color: var(--white);
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .widget-title {
            font-family: 'Playfair Display', serif;
            font-size: 18px;
            font-weight: 700;
            color: var(--primary-green);
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--border);
        }

        .trending-list {
            list-style: none;
        }

        .trending-item {
            display: flex;
            gap: 15px;
            padding: 15px 0;
            border-bottom: 1px solid var(--border);
        }

        .trending-item:last-child {
            border-bottom: none;
        }

        .trending-number {
            font-size: 24px;
            font-weight: 900;
            color: var(--accent-green);
            line-height: 1;
            min-width: 30px;
        }

        .trending-content h4 {
            font-size: 14px;
            font-weight: 600;
            line-height: 1.4;
            margin-bottom: 5px;
        }

        .trending-meta {
            font-size: 12px;
            color: var(--gray);
        }

        .ad-widget {
            background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
            border: 2px dashed var(--light-green);
            height: 250px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-green);
            font-weight: 500;
            border-radius: 8px;
        }

        /* Category Sections */
        .category-section {
            margin-bottom: 40px;
        }

        .category-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
        }

        .category-card {
            position: relative;
            height: 200px;
            border-radius: 8px;
            overflow: hidden;
            cursor: pointer;
        }

        .category-bg {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, var(--primary-green) 0%, var(--light-green) 100%);
            transition: transform 0.3s;
        }

        .category-card:hover .category-bg {
            transform: scale(1.1);
        }

        .category-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 20px;
            color: var(--white);
        }

        .category-name {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .category-count {
            font-size: 13px;
            opacity: 0.9;
        }

        /* Footer */
        .main-footer {
            background-color: var(--dark-gray);
            color: var(--white);
            padding: 50px 0 20px;
            margin-top: 50px;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 40px;
            margin-bottom: 40px;
        }

        .footer-brand .logo-text h2 {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            color: var(--accent-green);
            margin-bottom: 5px;
        }

        .footer-brand .slogan {
            color: rgba(255,255,255,0.7);
            margin-bottom: 20px;
        }

        .footer-about {
            font-size: 14px;
            line-height: 1.8;
            color: rgba(255,255,255,0.8);
            margin-bottom: 20px;
        }

        .footer-social {
            display: flex;
            gap: 10px;
        }

        .social-icon {
            width: 40px;
            height: 40px;
            background-color: rgba(255,255,255,0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            text-decoration: none;
            transition: all 0.3s;
        }

        .social-icon:hover {
            background-color: var(--accent-green);
            color: var(--dark-green);
            transform: translateY(-2px);
        }

        .footer-title {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 20px;
            color: var(--accent-green);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .footer-links {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 12px;
        }

        .footer-links a {
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            font-size: 14px;
            transition: color 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .footer-links a:hover {
            color: var(--accent-green);
            padding-left: 5px;
        }

        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            color: rgba(255,255,255,0.6);
        }

        .footer-nav {
            display: flex;
            gap: 20px;
        }

        .footer-nav a {
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-nav a:hover {
            color: var(--accent-green);
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .content-grid {
                grid-template-columns: 1fr;
            }
            
            .sidebar {
                display: none;
            }
            
            .hero-grid {
                grid-template-columns: 1fr;
            }
            
            .category-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .news-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .nav-menu {
                display: none;
            }
            
            .category-grid,
            .news-grid {
                grid-template-columns: 1fr;
            }
            
            .footer-grid {
                grid-template-columns: 1fr;
                gap: 30px;
            }
            
            .header-content {
                flex-direction: column;
                gap: 20px;
            }
            
            .header-ad {
                width: 100%;
            }
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .news-card {
            animation: fadeIn 0.6s ease-out forwards;
        }

        /* Hover Effects */
        .news-title:hover {
            color: var(--primary-green);
            cursor: pointer;
        }

        /* Loading State */
        .loading {
            background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
            background-size: 200% 100%;
            animation: loading 1.5s infinite;
        }

        @keyframes loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
    </style>
</head>
